# 剧本分镜智能体配置示例。请复制此文件为.env并填入实际的API密钥
# 详细参考 Github: https://github.com/neopen/video-shot-agent

# ================= 应用配置 =================
# 部署环境（development, production）
PENSHOT__APP__ENVIRONMENT=development
# 应用配置 调试模式，设置为True可启用详细日志
# PENSHOT__APP__DEBUG=true
# 剧本的语言设置，目前支持：zh（中文）或en（英文）
PENSHOT__APP__LANGUAGE=zh
# AI模型镜像
HF_ENDPOINT=https://hf-mirror.com

# ================= API配置 =================
#  服务器主机，支持HOST环境变量
PENSHOT__API__HOST=localhost
#  服务器端口，支持PORT环境变量
PENSHOT__API__PORT=8000
#  工作进程数，支持WORKERS环境变量
# PENSHOT__API__WORKERS=1
# PENSHOT__API__RELOAD=true

########################## LLM 模型配置 #########################
# 系统支持的厂商（openai, qwen, deepseek, ollama），当默认模型不可用时使用备用厂商

# ================= LLM默认配置 =================
# LLM 厂商 API
PENSHOT__LLM__DEFAULT__BASE_URL=https://api.openai.com/v1
# LLM 厂商 KAY
PENSHOT__LLM__DEFAULT__API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
# LLM 厂商 模型
PENSHOT__LLM__DEFAULT__MODEL_NAME=gpt-4o
# 生成温度参数，控制输出的随机性： 0.0 = 确定性输出，1.0 = 最大随机性
PENSHOT__LLM__DEFAULT__TEMPERATURE=0.1
# 默认API超时时间（秒）
PENSHOT__LLM__DEFAULT__TIMEOUT=60
# 最大重试次数
PENSHOT__LLM__DEFAULT__MAX_RETRIES=3
# 最大生成令牌数
PENSHOT__LLM__DEFAULT__MAX_TOKENS=8192
PENSHOT__LLM__DEFAULT__RETRY_DELAY=1

# ================= LLM备用配置 =================
PENSHOT__LLM__FALLBACK__BASE_URL=https://api.deepseek.com
PENSHOT__LLM__FALLBACK__API_KEY=xxxxxxxxxxxxxxxxxxxxxx
PENSHOT__LLM__FALLBACK__MODEL_NAME=deepseek-chat
PENSHOT__LLM__FALLBACK__TEMPERATURE=0.1
PENSHOT__LLM__FALLBACK__TIMEOUT=60
PENSHOT__LLM__FALLBACK__MAX_TOKENS=8192

########################## 嵌入模型配置 #########################
# 系统支持的厂商（openai, qwen, HuggingFace, ollama），当默认模型不可用时使用备用厂商

# ================ 嵌入模型默认配置 ================
PENSHOT__EMBED__DEFAULT__BASE_URL=https://api.openai.com/v1
PENSHOT__EMBED__DEFAULT__API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
# 中文常用模型：gte-large-zh，bge-large-zh-v1.5，text-embedding-3-small
PENSHOT__EMBED__DEFAULT__MODEL_NAME=text-embedding-3-small
PENSHOT__EMBED__DEFAULT__DEVICE=gpu
PENSHOT__EMBED__DEFAULT__NORMALIZE_EMBEDDINGS=true
PENSHOT__EMBED__DEFAULT__DIMENSIONS=1536
PENSHOT__EMBED__DEFAULT__TIMEOUT=60

# ================ 嵌入模型备用配置 ================
PENSHOT__EMBED__FALLBACK__BASE_URL=http://localhost:11434
PENSHOT__EMBED__FALLBACK__API_KEY=xxxxxxxxxxxxxxxxxxxxxx
PENSHOT__EMBED__FALLBACK__MODEL_NAME=text-embedding-3-small
PENSHOT__EMBED__FALLBACK__DEVICE=gpu
PENSHOT__EMBED__FALLBACK__TIMEOUT=60


########################## Redis 配置 ##########################
# Redis 单节点配置，支持使用完整的URL参数配置：REDIS_URL=redis://:password@localhost:6379/0
PENSHOT__REDIS_HOST=localhost
PENSHOT__REDIS_PORT=6379
PENSHOT__REDIS_DB=0
PENSHOT__REDIS_PASSWORD=
PENSHOT__REDIS_SSL=false

# 连接池配置
PENSHOT__REDIS_MAX_CONNECTIONS=10
PENSHOT__REDIS_SOCKET_TIMEOUT=20
PENSHOT__REDIS_CONNECT_TIMEOUT=20
PENSHOT__REDIS_RETRY_ON_TIMEOUT=true
PENSHOT__REDIS_DECODE_RESPONSES=true

# 集群模式配置（如果需要）
# PENSHOT__REDIS_CLUSTER=false
# PENSHOT__REDIS_STARTUP_NODES=node1:7000,node2:7001,node3:7002

# SSL配置
# PENSHOT__REDIS_SSL_CERT_REQS=required

########################## 注意事项 ##############################
# 1. 请确保设置有效的AI API密钥
# 2. 对于中文剧本，推荐使用支持中文的模型
# 3. 调试模式会记录详细日志，可能会包含敏感信息